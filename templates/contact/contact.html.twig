{% extends 'base.html.twig' %}

{% block body %}

<div class="container py-4">
    <form class="mx-auto" style="max-width: 800px;">
        
        <div class="row mb-3">
            <label for="email" class="col-md-2 col-form-label">
                E-mail
            </label>

            <div class="col-md-10">
                <input
                    type="email"
                    class="form-control"
                    id="email"
                    placeholder="name@example.com">
            </div>
        </div>

        <div class="row mb-3">
            <label for="message" class="col-md-2 col-form-label">
                Missatge
            </label>

            <div class="col-md-10">
                <textarea
                    class="form-control"
                    id="message"
                    rows="6"></textarea>
            </div>
        </div>

        <div class="row">
            <div class="col-md-10 offset-md-2">
                <button type="submit" class="btn btn-secondary">
                    Enviar
                </button>
            </div>
        </div>

    </form>
</div>
{% endblock %}