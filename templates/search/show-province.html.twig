{% extends 'base.html.twig' %}

{% block title %}Restaurants vegetarians en {{ province.name }}{% endblock %}

{% block sentence %}
{% endblock %}    

{% block body %}
<div class="container-responsive m-4">

    {% if restaurants|length == 0 %}
        <div class="alert alert-warning">
            No hi ha restaurants vegetarians {{ province.name }}!
            <br>
            
        </div>

    {% else %}
    <h4 class="m-5 text-center">Restaurants vegetarians en {{ province.name }}</h4>


    {% endif %}

    {% for restaurant in restaurants %}
                                
                <div class="card mb-3 bordered border-primary border-2">
                    <div class="card-header bg-primary">
                        <div class="col-6 d-flex justify-content-center">
                            <h5 class="card-title text-center text-white w-100">{{ restaurant.name }}</h5>
                        </div>
                        <div class="col-2"></div>
                    </div>
                    <div class="card-body">
                        <div class="d-grid gap-3">
                            <div class="row">
                                <div class="col-12 col-sm-6 d-flex flex-column align-items-center">
                                    <img src="{{ asset('media/restaurants/' ~ restaurant.slug ~ '.webp') }}" class="img border border-gray rounded" alt="Foto de {{ restaurant.name }}" height="200" width="200">
                                    <a href="{{ restaurant.website }}" class="btn btn-secondary rounded text-white w-50 m-3" target="_blank" rel="noopener noreferrer">Web</a>
                                </div>
                                <div class="col-12 col-sm-6 d-flex flex-column align-self-center">
                                    <p class="card-text text-start">Adreça: <a 
                                        href="https://www.google.com/maps/search/?api=1&query={{ (restaurant.name ~ ', ' ~ restaurant.address ~ ', ' ~ restaurant.province.name ~ ', Spain')|url_encode }}"
                                        target="_blank"
                                        rel="noopener noreferrer"
                                        > {{ restaurant.address }}</a></p>
                                    <p class="card-text text-start">Telèfon: <a href="tel:{{ restaurant.phone|replace({' ': ''}, '') }}">{{ restaurant.phone }}</a></p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
    {% endfor %}
</div>
{% endblock %}